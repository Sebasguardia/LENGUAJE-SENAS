# ⚙️ Configuración del Servidor
PROJECT_NAME="Lenguaje Senas Backend"
API_V1_STR="/api/v1"

# 🗄️ Base de Datos
# Desarrollo (SQLite): sqlite:///./app.db
# Producción (PostgreSQL): postgresql://usuario:password@host:puerto/nombre_db
DATABASE_URL=sqlite:///./app.db

# 🔐 Seguridad (Generar claves seguras de 32+ caracteres)
SECRET_KEY=cambiar_esta_clave_por_una_segura_en_produccion_12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 👤 Configuración Admin Inicial (Se crea al iniciar la app)
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123

# 📧 Configuración SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=True
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD="tu-app-password-de-gmail"
EMAILS_FROM_EMAIL=tu-correo@gmail.com
EMAILS_FROM_NAME="Instituto Señas IA"

# 🌐 Google OAuth
GOOGLE_CLIENT_ID=tu-google-client-id.apps.googleusercontent.com
